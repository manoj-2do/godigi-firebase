rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /trip_tracking/{jobId} {
      allow read: if (resource.data.token_expires_at != null && resource.data.token_expires_at > request.time);
      allow write: if request.auth != null;
    }

    // Lookup doc: unauthenticated get by link_signature (doc ID), only while link is valid.
    match /tracking_links/{signature} {
      allow get: if resource.data.tracking_link_expires_at > request.time;
      allow write: if request.auth != null;
    }

    // Task doc: unauthenticated get by task_id (doc ID), only while link is valid.
    // Authenticated users can read/list freely for ops apps.
    match /tasks/{taskId} {
      allow read: if request.auth != null
                  || resource.data.tracking_link_expires_at > request.time;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
