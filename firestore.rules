rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /trip_tracking/{jobId} {
      allow read: if (resource.data.token_expires_at != null && resource.data.token_expires_at > request.time);
      allow write: if request.auth != null;
    }

    // Public tracking page: /track/<link_signature> — unauthenticated read only while link is valid.
    // Authenticated users may read tasks for ops apps.
    match /tasks/{taskId} {
      allow read: if request.auth != null
        || (resource.data.tracking_link_expires_at != null
            && resource.data.tracking_link_expires_at > request.time)
        || (resource.data.token_expires_at != null
            && resource.data.token_expires_at > request.time);

      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
