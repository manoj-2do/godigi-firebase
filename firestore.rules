rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /trip_tracking/{jobId} {
      allow read: if (resource.data.token_expires_at != null && resource.data.token_expires_at > request.time);
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
